# Server Configuration
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001

# Security (REQUIRED in production)
# Generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# Database
DB_PATH=./data/sentquote.db

# CORS (optional - defaults to allow all)
# CORS_ORIGIN=https://yoursite.com,https://app.yoursite.com

# Email Configuration (optional - followups won't work without this)
# For production, use a real SMTP service like SendGrid, AWS SES, or Postmark
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
FROM_EMAIL=noreply@sentquote.com

# Stripe Configuration (optional - payments won't work without this)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Logging
LOG_LEVEL=info

# App Settings
APP_NAME=SentQuote
